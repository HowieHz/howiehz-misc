{
  "extends": "../tsconfig.json",
  "references": [
    {
      "path": "../packages/compat-finder/tsconfig.neutral.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "noEmit": true,
    "isolatedDeclarations": false,
  },
  "vueCompilerOptions": {
    "extensions": [".vue"],
    "vitePressExtensions": [".md"]
  },
  "include": [".vitepress/theme/**/*.ts", ".vitepress/types/**/*.d.ts", "**/*.vue", "**/*.md", ".vitepress/**/*.vue"],
  "exclude": ["**/README.md"]
}
