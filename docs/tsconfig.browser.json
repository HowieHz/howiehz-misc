{
  "extends": "../tsconfig.json",
  "references": [
    {
      "path": "../packages/compat-finder/tsconfig.neutral.json"
    }
  ],
  "compilerOptions": {
    "declarationDir": "../node_modules/.tmp/types/docs/app",
    "lib": ["esnext", "dom", "dom.iterable"]
  },
  "vueCompilerOptions": {
    "extensions": [".vue"],
    "vitePressExtensions": [".md"]
  },
  "include": [".vitepress/theme/**/*.ts", ".vitepress/types/**/*.d.ts", "**/*.vue", "**/*.md"],
  "exclude": ["**/README.md"]
}
