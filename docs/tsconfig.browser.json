{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "../tsconfig/tsconfig.browser.json",
  "references": [
    {
      // Some Markdown files import VitePress *.data.ts modules, so this config references the Node tsconfig when generating their type declarations.
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "declarationDir": "../node_modules/.tmp/types/docs/browser",
    "isolatedDeclarations": false
  },
  "vueCompilerOptions": {
    "extensions": [".vue"],
    "vitePressExtensions": [".md"]
  },
  "include": [
    ".vitepress/theme/**/*.ts",
    ".vitepress/types/browser/*.d.ts",
    "tools/**/*.ts",
    "en/tools/**/*.ts",
    "**/*.vue",
    "**/*.md",
    ".vitepress/**/*.vue"
  ],
  "exclude": ["**/README.md", "CHANGELOG.md"]
}
