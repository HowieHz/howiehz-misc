{
  "name": "howiehz-misc",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Misc Site: For things that don't belong on the main site.",
  "keywords": [
    "HowieHz"
  ],
  "homepage": "https://howiehz.top/misc",
  "bugs": {
    "url": "https://github.com/HowieHz/howiehz-misc/issues"
  },
  "license": "MIT",
  "author": "HowieHz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HowieHz/howiehz-misc.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm run compat-finder:build && pnpm run docs:build",
    "compat-finder": "node --experimental-strip-types packages/compat-finder/src/cli.ts",
    "compat-finder:build": "pnpm --filter compat-finder build",
    "compat-finder:build:release": "pnpm --filter compat-finder build:release",
    "compat-finder:test": "pnpm --filter compat-finder test",
    "compat-finder:watch": "pnpm --filter compat-finder watch",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview",
    "docs:test": "pnpm --filter docs test",
    "docs:watch": "pnpm --filter docs watch",
    "fmt": "pnpm run \"/^fmt:/\"",
    "fmt:oxfmt": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,ts,vue,html}\"",
    "lint": "pnpm run \"/^lint:/\"",
    "lint:autocorrect": "autocorrect --fix",
    "lint:md": "markdownlint --fix \"**/*.md\" --ignore-path .gitignore",
    "lint:oxlint+eslint": "oxlint --type-aware --fix && eslint --fix",
    "lint:style": "stylelint --fix \"**/*.{css,vue}\" \"docs/.vitepress/**/*.{css,vue}\" --ignore-path .gitignore",
    "lint:type-check": "tsgo -b",
    "migrate:oxlint": "pnpm dlx @oxlint/migrate --type-aware --with-nursery && pnpm oxfmt -- --write .oxlintrc.json",
    "preinstall": "npx only-allow pnpm",
    "test": "pnpm run \"/:test$/\"",
    "watch": "pnpm run \"/:watch$/\""
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript/native-preview": "7.0.0-dev.20260418.1",
    "autocorrect-node": "^2.14.0",
    "browserslist": "^4.28.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "^1.60.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.0",
    "stylelint": "^17.8.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.16",
    "vue-eslint-parser": "^10.4.0"
  },
  "browserslist": [
    "defaults",
    "Safari >= 16.4",
    "Chrome >= 111",
    "Firefox >= 128"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": "^10.33.0"
  },
  "packageManager": "pnpm@10.33.0"
}
