{
  "name": "howiehz-misc",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Misc Site: For things that don't belong on the main site.",
  "keywords": [
    "HowieHz"
  ],
  "homepage": "https://howiehz.top/misc",
  "bugs": {
    "url": "https://github.com/HowieHz/howiehz-misc/issues"
  },
  "license": "MIT",
  "author": "HowieHz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HowieHz/howiehz-misc.git"
  },
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "compat-finder:benchmark": "pnpm --filter compat-finder benchmark",
    "compat-finder:build": "pnpm --filter compat-finder build",
    "compat-finder:build:release": "pnpm --filter compat-finder build:release",
    "compat-finder:cli": "pnpm --filter compat-finder cli",
    "compat-finder:test": "pnpm --filter compat-finder test",
    "compat-finder:watch": "pnpm --filter compat-finder watch",
    "docs:build": "pnpm run compat-finder:build && pnpm --filter docs build",
    "docs:preview": "pnpm run compat-finder:build && pnpm --filter docs preview",
    "docs:watch": "pnpm --parallel --stream --filter compat-finder --filter docs watch",
    "fmt": "pnpm run \"/^fmt:/\"",
    "fmt:oxfmt": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,mjs,ts,vue,html}\"",
    "lint": "pnpm run \"/^lint:/\"",
    "lint:autocorrect": "autocorrect --fix",
    "lint:md": "markdownlint --fix \"**/*.md\" --ignore-path .gitignore",
    "lint:oxlint+eslint": "oxlint --type-aware --fix && eslint --fix",
    "lint:style": "stylelint --fix \"**/*.{css,vue}\" \"docs/.vitepress/**/*.{css,vue}\" --ignore-path .gitignore",
    "lint:type-check:docs:vue-tsc": "vue-tsc -b docs/tsconfig.browser.json",
    "lint:type-check:tsgo": "tsgo -b",
    "migrate:oxlint": "pnpm dlx @oxlint/migrate --type-aware --with-nursery && pnpm oxfmt -- --write .oxlintrc.json",
    "preinstall": "npx only-allow pnpm",
    "prelint:type-check:docs:vue-tsc": "pnpm run compat-finder:build",
    "test": "pnpm run \"/:test$/\""
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript/native-preview": "7.0.0-dev.20260425.1",
    "autocorrect-node": "^2.14.0",
    "browserslist": "^4.28.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "^1.61.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.9.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript-eslint": "^8.59.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  },
  "browserslist": [
    "defaults",
    "Safari >= 16.4",
    "Chrome >= 111",
    "Firefox >= 128"
  ],
  "engines": {
    "node": "^22 || >=24",
    "pnpm": "^10.33.2"
  },
  "packageManager": "pnpm@10.33.2"
}
