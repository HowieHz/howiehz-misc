{
  "extends": "./tsconfig.json",
  "references": [
    {
      "path": "./tsconfig.shared.json"
    },
    {
      "path": "./packages/compat-finder/tsconfig.json"
    }
  ],
  "compilerOptions": {
    "composite": true,
    "declaration": true, // composite 已隐式启用 declaration，这里显式保留以强化意图
    "emitDeclarationOnly": true,
    "declarationDir": "./node_modules/.tmp/types/app",
    "lib": ["esnext", "dom", "dom.iterable"]
  },
  "include": ["docs/.vitepress/theme/**/*.ts", "docs/.vitepress/types/**/*.d.ts"]
}
