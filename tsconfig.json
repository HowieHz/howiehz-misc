{
  "files": [],
  "references": [
    {
      "path": "./packages/compat-finder/tsconfig.json"
    },
    {
      "path": "./docs/tsconfig.json"
    }
  ],
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true // 启用了 verbatimModuleSyntax 后这个冗余，但保持明确声明符合文档 https://cn.vitejs.dev/guide/features#isolatedmodules
  }
}
