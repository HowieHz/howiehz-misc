{
  "extends": "./tsconfig.json",
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ],
  "compilerOptions": {
    "composite": true,
    "declaration": true, // composite 已隐式启用 declaration，这里显式保留以强化意图
    "emitDeclarationOnly": true,
    "declarationDir": "./node_modules/.tmp/types/node",
    "lib": ["esnext"],
    "types": ["node"]
  },
  "include": [
    "docs/.vitepress/config.ts",
    "docs/.vitepress/data/**/*.ts",
    "docs/.vitepress/utils/**/*.ts",
    "docs/.vitepress/types/**/*.d.ts",
    "docs/**/*.data.ts"
  ]
}
